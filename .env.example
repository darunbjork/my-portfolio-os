PORT=
NODE_ENV=

# Frontend URL
FRONTEND_URL=# Should match the URL of your frontend application

# MongoDB Configuration
MONGO_URI=
JWT_SECRET=your_super_secret_jwt_key

# SendGrid Email Configuration
